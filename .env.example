# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret for signing JWT HttpOnly session cookies (Do not use default, must be secure)
JWT_SECRET=

# Separate secret TOKEN_ENCRYPTION_KEY (min 32 chars) for AES-256 token encryption
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Optional domain-wide domain restriction (e.g. "example.com"). Leave empty to allow any domain.
ALLOWED_DOMAIN=

# Database configuration backend. Supported: file | postgres
DB_BACKEND=file
# Required if DB_BACKEND=postgres
DATABASE_URL=


